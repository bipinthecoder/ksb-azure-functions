# =======================================================================
# .env.example — template for local development secrets
# =======================================================================
# THIS FILE IS SAFE TO COMMIT — it contains no real credentials.
#
# To get started:
#   cp .env.example .env
#   (then fill in any values marked <replace-this>)
#
# For local Docker development the Azurite and Cosmos emulator values
# are pre-filled with the known public dev credentials — just copy as-is.
# =======================================================================


# -----------------------------------------------------------------------
# Azurite (local blob storage emulator)
# -----------------------------------------------------------------------
AZURITE_ACCOUNT_KEY=<azurite-dev-account-key>
AZURITE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=<azurite-dev-account-key>;BlobEndpoint=http://azurite:10000/devstoreaccount1;


# -----------------------------------------------------------------------
# Cosmos DB emulator
# -----------------------------------------------------------------------
COSMOS_DB_KEY=<cosmos-emulator-or-azure-key>
COSMOS_DB_ENDPOINT=https://cosmosdb:8081/


# -----------------------------------------------------------------------
# Non-secret configuration
# -----------------------------------------------------------------------
COSMOS_DB_DATABASE=ksb-db
COSMOS_DB_CONTAINER=results
COSMOS_DB_DISABLE_SSL_VERIFY=true
STORAGE_BLOB_BASE_URL=http://localhost:10000/devstoreaccount1
